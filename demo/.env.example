# ============================================
# 弁当予約管理システム 環境変数設定例
# ============================================
# このファイルを .env にコピーして必要な値を設定してください

# データベース接続
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3308/bento_db?useSSL=false&serverTimezone=Asia/Tokyo&allowPublicKeyRetrieval=true&useUnicode=true&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# JWT設定（本番環境では必ず変更してください）
APP_JWT_SECRET=your-strong-random-secret-key-at-least-256-bits
APP_JWT_EXPIRATION_MS=86400000

# メール送信設定
# メールを有効にするには true に設定し、SMTP認証情報を入力してください
APP_MAIL_ENABLED=true
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-app-password

# フロントエンドURL（メール内リンク用）
APP_FRONTEND_BASE_URL=http://localhost:5174